# CompliScan — Environment Variables Example
# Copiază în `.env.local` și completează valorile pentru development local.
# Production: setează prin Vercel Dashboard > Environment Variables.
#
# Updated: 28 apr 2026 (Sprint 0-3 complete, ready for production launch).

# ── Supabase (opțional pentru dev, REQUIRED pentru production) ───────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Dacă folosești backend-ul `supabase` și activezi planurile Stripe,
# asigură-te că tabela `public.plans` există în baza de date.

# ── AI / LLM (Gemini default + Mistral EU sovereignty option) ────────────────
# Cel puțin unul dintre Gemini sau Mistral este REQUIRED pentru document generation.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# S2B.1 — Mistral Large 2 (EU sovereignty option, sediu Paris)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# Default global AI provider (overridable per cabinet în Settings → Branding)
COMPLISCAN_AI_PROVIDER=gemini       # gemini | mistral

# ── Google Cloud Vision (OCR pentru scan documente) ──────────────────────────
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_VISION_LOCATION=eu
GOOGLE_CLOUD_VISION_API_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────────
COMPLISCAN_SESSION_SECRET=          # minim 32 caractere random; folosește `openssl rand -base64 48`
SHARE_TOKEN_SECRET=                 # secret HMAC pentru magic links /shared/[token]

# ── Backend mode (S2A.7) ─────────────────────────────────────────────────────
COMPLISCAN_AUTH_BACKEND=local       # local | supabase
COMPLISCAN_DATA_BACKEND=local       # local | supabase | dual-write | hybrid
COMPLISCAN_ALLOW_LOCAL_FALLBACK=true
# Dual-write playbook (production cutover):
#   1. npm run migrate:fs-to-supabase:apply  # one-time copy .data/ → Supabase
#   2. Set DATA_BACKEND=dual-write           # 1 săpt monitor logs
#   3. Verify zero discrepancies              # `[dual-write] discrepancy` warnings
#   4. Set DATA_BACKEND=supabase              # cutover real

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=                     # https://resend.com/api-keys
ALERT_EMAIL_FROM=noreply@compliscan.ro

# S1.8 — Cabinet email override pentru notificări magic link patron actions
COMPLISCAN_CABINET_EMAIL_FROM=      # ex: "DPO Complet <noreply@dpocomplet.ro>"
COMPLISCAN_CABINET_NOTIFICATION_EMAIL=  # email destinatar (override pentru toți cabinets fără owner)

# ── Cron / automation ────────────────────────────────────────────────────────
CRON_SECRET=                        # Bearer token folosit de rutele /api/cron/*
                                    # Vercel Cron îl pune automat în header

# ── ANAF SPV e-Factura — MOD REAL ────────────────────────────────────────────
ANAF_CLIENT_ID=
ANAF_CLIENT_SECRET=
ANAF_REDIRECT_URI=
ANAF_CUI=

# ── Stripe (plăți abonament) ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=                  # sk_live_... sau sk_test_...
STRIPE_WEBHOOK_SECRET=              # whsec_... din Stripe Dashboard > Webhooks

# Legacy SKU (backward compat existing customers)
STRIPE_PRICE_PRO_MONTHLY=           # price_... din Stripe Dashboard > Products
STRIPE_PRICE_PARTNER_MONTHLY=
STRIPE_PRICE_PARTNER_10_MONTHLY=    # opțional, fallback la PARTNER_MONTHLY
STRIPE_PRICE_PARTNER_25_MONTHLY=
STRIPE_PRICE_PARTNER_50_MONTHLY=

# S2A.1 — ICP tier mapping (Doc 06, 14 SKU pentru cele 5 ICP segments)
# Solo segment (Owner/Manager IMM mic)
STRIPE_PRICE_SOLO_STARTER_MONTHLY=  # €49 / lună
STRIPE_PRICE_SOLO_PRO_MONTHLY=      # €99 / lună
# IMM Internal segment
STRIPE_PRICE_IMM_INTERNAL_SOLO_MONTHLY=  # €99 / lună
STRIPE_PRICE_IMM_INTERNAL_PRO_MONTHLY=   # €299 / lună
# Cabinet DPO segment
STRIPE_PRICE_CABINET_SOLO_MONTHLY=   # €499 / lună (10 clienți)
STRIPE_PRICE_CABINET_PRO_MONTHLY=    # €999 / lună (25 clienți)
STRIPE_PRICE_CABINET_STUDIO_MONTHLY= # €1999 / lună (50 clienți)
# Cabinet Fiscal (Contabil CECCAR) segment
STRIPE_PRICE_FISCAL_SOLO_MONTHLY=    # €299 / lună (25 clienți)
STRIPE_PRICE_FISCAL_PRO_MONTHLY=     # €699 / lună (100 clienți)
# Enterprise segment — sales-led, NU configurat în Stripe automat

NEXT_PUBLIC_APP_URL=                # https://app.compliscan.ro (fără slash final)

# ── White-label / Cabinet branding default (S0 + S1.5) ───────────────────────
# Folosit pe /shared/[token] page când white-label per org lipsește.
COMPLISCAN_CABINET_NAME=             # ex: "DPO Complet"
COMPLISCAN_CONSULTANT_NAME=          # ex: "Diana Popescu"
COMPLISCAN_CONSULTANT_TITLE=         # ex: "Consultant DPO"
COMPLISCAN_CONSULTANT_CERTIFICATION= # ex: "CIPP/E"
COMPLISCAN_CONSULTANT_EMAIL=         # ex: "diana@dpocomplet.ro"
COMPLISCAN_CONSULTANT_PHONE=         # ex: "+40 700 000 000"

# ── Sentry (monitoring) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                  # pentru upload source maps în CI / Vercel
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=                     # optional override; implicit folosește VERCEL_GIT_COMMIT_SHA
